config sbproxy 'config'
	option enabled '0'
	option log_level 'warn'
	option proxy_mode 'redirect_tproxy'
	option main_node 'direct_default'
	option mixed_port '7890'
	option dns_port '1053'
	option clash_api_enabled '1'
	option clash_api_controller '0.0.0.0:9090'
	option clash_api_ui 'dashboard'
	option default_dns_server 'wan_dns'

config dns_server 'wan_dns'
	option enabled '1'
	option label 'wan-dns'
	option type 'udp'
	option server '223.5.5.5'
	option server_port '53'
	option detour 'direct-out'

config subscription 'main'
	option enabled '0'
	option url ''
	option user_agent 'SBProxy/0.2'
	option allow_insecure '0'

config node 'direct_default'
	option enabled '1'
	option label 'direct-out'
	option type 'direct'

config node 'block_default'
	option enabled '1'
	option label 'block-out'
	option type 'block'
