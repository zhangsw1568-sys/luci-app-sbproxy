#!/bin/sh /etc/rc.common
USE_PROCD=1

START=99
STOP=10

CONF="sbproxy"
PROG="/usr/bin/sing-box"
SB_DIR="/etc/sbproxy"
RUN_DIR="/var/run/sbproxy"
LOG_PATH="$RUN_DIR/sbproxy.log"

log() {
	mkdir -p "$RUN_DIR"
	echo "$(date '+%Y-%m-%d %H:%M:%S') [SBPROXY] $*" >> "$LOG_PATH"
}

start_service() {
	config_load "$CONF"

	local enabled
	config_get enabled config enabled 0
	[ "$enabled" = "1" ] || {
		log "Service disabled."
		return 0
	}

	mkdir -p "$RUN_DIR"

	if ! ucode -S "$SB_DIR/scripts/generate_client.uc" 2>>"$LOG_PATH"; then
		log "Failed to generate config."
		return 1
	fi

	if [ ! -s "$RUN_DIR/sing-box.json" ]; then
		log "Generated config missing."
		return 1
	fi

	if ! "$PROG" check --config "$RUN_DIR/sing-box.json" >>"$LOG_PATH" 2>&1; then
		log "sing-box check failed."
		return 1
	fi

	procd_open_instance
	procd_set_param command "$PROG"
	procd_append_param command run --config "$RUN_DIR/sing-box.json"
	procd_set_param respawn
	procd_set_param stderr 1
	procd_set_param stdout 1
	procd_close_instance

	log "Started."
}

stop_service() {
	log "Stopped."
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "$CONF"
}
